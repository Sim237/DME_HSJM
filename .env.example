# ============================================================
# FICHIER : .env.example
# TEMPLATE DE CONFIGURATION — NE PAS MODIFIER CE FICHIER
# Copier ce fichier en ".env" et renseigner vos valeurs locales
# Ce fichier .env.example EST commité sur git (c'est le template)
# Le fichier .env NE DOIT JAMAIS être commité sur git
# ============================================================

# --- BASE DE DONNÉES ---
DB_HOST=localhost
DB_NAME=dme_hospital
DB_USER=root
DB_PASS=VotreMotDePasseIci

# --- URL DE L'APPLICATION ---
# MAMP Mac (dossier racine)     : http://localhost:8080/
# MAMP Mac (sous-dossier)       : http://localhost:8080/DME_HSJM/
# XAMPP Windows (sous-dossier)  : http://localhost/DME_HSJM/
# Serveur de production         : https://votre-domaine.com/
BASE_URL=http://localhost:8080/

# --- ENVIRONNEMENT ---
# development | production
APP_ENV=development

# --- DEBUG ---
# true en dev, false en production
APP_DEBUG=true
