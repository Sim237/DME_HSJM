# ============================================================
# FICHIER : .env.example  — TEMPLATE (commité sur git)
# ============================================================
# Copier ce fichier en ".env" et renseigner vos valeurs locales
#
#   cp .env.example .env
#
# ⚠️  Le fichier .env NE doit JAMAIS être commité sur git
# ============================================================

# --- BASE DE DONNÉES ---
DB_HOST=localhost
DB_NAME=dme_hospital
DB_USER=root
DB_PASS=                        # Votre mot de passe MySQL local

# --- URL DE L'APPLICATION ---
# La valeur dépend de votre configuration MAMP :
#
#   Config A — DocumentRoot pointe DIRECTEMENT sur DME_HSJM :
#   BASE_URL=http://localhost:8080/
#
#   Config B — Projet dans un sous-dossier /dme_hospital/ :
#   BASE_URL=http://localhost:8080/dme_hospital/
#
# ⚠️  BASE_URL et RewriteBase (.htaccess) doivent être cohérents
#     .htaccess est configuré pour Config A (RewriteBase /)
#     → Tous les développeurs doivent utiliser Config A
#
BASE_URL=http://localhost:8080/

# --- ENVIRONNEMENT ---
# development | production
APP_ENV=development

# --- DEBUG ---
# true en dev, false en production absolument
APP_DEBUG=true
