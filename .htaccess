# 1. Empêcher l'affichage des dossiers (Sécurité)
Options -Indexes
Options -MultiViews

# 2. Activer le moteur de réécriture
RewriteEngine On

# 3. Définir la base (DocumentRoot pointe directement sur DME_HSJM)
RewriteBase /

# 4. Support des fichiers DICOM (pour que le navigateur les reconnaisse)
AddType application/dicom .dcm
AddType application/dicom .dicom

# 5. Forcer le type MIME pour les images de preview
AddType image/jpeg .jpg .jpeg

# 6. CONDITIONS : Si le fichier ou dossier existe physiquement, on ne fait rien
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# 7. RÈGLE : Sinon, on redirige tout vers index.php
# Le [L] signifie "Last" (dernière règle), [QSA] garde les paramètres ?id=...
RewriteRule ^(.*)$ index.php [QSA,L]

# 8. Protection des fichiers sensibles (Optionnel mais recommandé)
<FilesMatch "\.(sql|log|ini|sh|bak)$">
    Order allow,deny
    Deny from all
</FilesMatch>